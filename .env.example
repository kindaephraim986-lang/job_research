# ========================================
# 🔐 CONFIGURATION AFRIJOB - TEMPLATE
# ========================================
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# ========================================
# 📊 ENVIRONNEMENT
# ========================================
NODE_ENV=production
# Options: development, staging, production
DEBUG=false

# ========================================
# 🗄️ BASE DE DONNÉES
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=afrijob_user
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE_CHANGE_THIS
DB_NAME=bddiane_sp

# Root pour initial setup (pas pour production)
DB_ROOT_PASSWORD=

# ========================================
# 🔑 AUTHENTIFICATION & SÉCURITÉ
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string
JWT_EXPIRY=7d
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

FILE_SIGNATURE_SECRET=your-file-signature-secret-key
FILE_URL_EXPIRY=3600
# Expiration en secondes (3600 = 1 heure)

# ========================================
# 🌐 SERVEUR
# ========================================
BACKEND_PORT=5000
FRONTEND_PORT=3000
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ========================================
# 💾 STOCKAGE DE FICHIERS
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
# 10MB en bytes

PROFILE_PHOTO_DIR=./uploads/profile-photos
PROFILE_PHOTO_MAX_SIZE=5242880
# 5MB

# ========================================
# ☁️ STOCKAGE CLOUD (Optionnel)
# ========================================
USE_S3=false
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=afrijob-uploads
AWS_S3_URL=https://s3.amazonaws.com/afrijob-uploads

# ========================================
# 📧 EMAIL (Optionnel)
# ========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@afrijob.com
MAIL_PASSWORD=
MAIL_FROM=AfriJob <noreply@afrijob.com>

# ========================================
# 📱 SMS & NOTIFICATIONS (Optionnel)
# ========================================
SMS_PROVIDER=twilio
# Options: twilio, nexmo, afristing

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ========================================
# 💳 PAIEMENTS
# ========================================
PAYMENT_PROVIDER=stripe
# Options: stripe, paypal, wave

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

PAYPAL_MODE=sandbox
# Options: sandbox, live
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ========================================
# 🔍 LOGS & MONITORING
# ========================================
LOG_LEVEL=info
# Options: error, warn, info, debug, trace

LOG_FILE=/var/log/afrijob/backend.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# ========================================
# 📊 ANALYTICS (Optionnel)
# ========================================
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=
# Pour error tracking: https://sentry.io

# ========================================
# 🔐 CORS & SESSIONS
# ========================================
CORS_ORIGIN=https://yourdomain.com
CORS_CREDENTIALS=true

SESSION_SECRET=your-session-secret-key
SESSION_EXPIRY=2592000
# 30 jours en secondes

# ========================================
# 🚀 DÉPLOIEMENT DOCKER
# ========================================
COMPOSE_PROJECT_NAME=afrijob
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_BACKEND=afrijob-backend
DOCKER_IMAGE_FRONTEND=afrijob-frontend
DOCKER_TAG=latest

# ========================================
# ⏰ JOBS CRON (Optionnel)
# ========================================
RUN_DAILY_CLEANUP=true
RUN_WEEKLY_REPORTS=true
RUN_MONTHLY_ARCHIVE=true

# ========================================
# 🛡️ RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW=15
# Fenêtre en minutes
RATE_LIMIT_MAX_REQUESTS=100
# Requêtes par fenêtre

# ========================================
# 🧪 TESTING
# ========================================
TEST_DATABASE_URL=mysql://test:test@localhost/afrijob_test
TEST_JWT_SECRET=test-jwt-secret
TEST_FILE_SIGNATURE_SECRET=test-file-secret

# ========================================
# 📍 PROXY (Si derrière un proxy)
# ========================================
PROXY_URL=
PROXY_AUTH=

# ========================================
# 🌍 GÉOLOCALISATION (Optionnel)
# ========================================
GEOLOCATION_API_KEY=
# Exemple: Google Maps API

# ========================================
# 🎯 PRODUCTION ESSENTIALS CHECKLIST
# ========================================
# [ ] DB_PASSWORD: changé vers un mot de passe sécurisé
# [ ] JWT_SECRET: changé vers une clé aléatoire
# [ ] FILE_SIGNATURE_SECRET: changé vers une clé aléatoire
# [ ] FRONTEND_URL: défini vers votre domaine
# [ ] BACKEND_URL: défini vers votre domaine
# [ ] LOG_FILE: pointant vers un répertoire writable
# [ ] CORS_ORIGIN: restricted à votre domaine
# [ ] NODE_ENV: défini à 'production'
# [ ] DEBUG: défini à 'false'
# [ ] PAYMENT_PROVIDER: configuré pour production

# ========================================
# 🔄 COMMANDES UTILES
# ========================================
# 
# 1. Générer une JWT_SECRET sécurisée:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Tester la connexion base de données:
#    mysql -h $DB_HOST -u $DB_USER -p$DB_PASSWORD -e "SELECT 1"
#
# 3. Voir les logs en temps réel:
#    tail -f /var/log/afrijob/backend.log
#
# 4. Vérifier les variables chargées:
#    node -e "require('dotenv').config(); console.log(process.env)"
# 
# ========================================
